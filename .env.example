# EmailJS credentials — copy this file to .env and fill in your values
# Get these from https://dashboard.emailjs.com after following EMAILJS_SETUP.md

VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_SUBSCRIBER_TEMPLATE=your_subscriber_template_id_here
VITE_EMAILJS_NOTIFY_TEMPLATE=your_notify_template_id_here
VITE_OWNER_EMAIL=your@email.com
